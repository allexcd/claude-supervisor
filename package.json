{
  "name": "claude-supervisor",
  "version": "1.0.0",
  "description": "Spin up parallel Claude Code agents in isolated git worktrees",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allexcd/claude-supervisor.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "supervisor": "bin/supervisor.sh",
    "supervisor.sh": "bin/supervisor.sh",
    "spawn-agent": "bin/spawn-agent.sh",
    "spawn-agent.sh": "bin/spawn-agent.sh",
    "collect-learnings": "bin/collect-learnings.sh",
    "collect-learnings.sh": "bin/collect-learnings.sh"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/",
    "VERSION",
    "LICENSE",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "scripts": {
